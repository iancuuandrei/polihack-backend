    ],
    "corpus_id": "ro.constitutia"
  },
  {
    "id": "ro.constitutia.titlu_ii.capitol_i.art_15",
    "type": "articol",
    "raw_text": "Art. 15",
    "hierarchy_path": [
      "II",
      "I",
      "15"
    ],
    "corpus_id": "ro.constitutia"
  },
  {
    "id": "ro.constitutia.titlu_ii.capitol_i.art_15.alin_1",
    "type": "alineat",
    "raw_text": "(1) Cetatenii beneficiaza de drepturile si libertatile consacrate prin Constitutie.",
    "hierarchy_path": [
      "II",
      "I",
      "15",
      "1"
    ],
    "corpus_id": "ro.constitutia"
  },
  {
    "id": "ro.constitutia.titlu_ii.capitol_i.art_15.alin_2",
    "type": "alineat",
    "raw_text": "(2) Legea dispune numai pentru viitor, cu exceptia legii penale mai favorabile.",
    "hierarchy_path": [
      "II",
      "I",
      "15",
      "2"
    ],
    "corpus_id": "ro.constitutia"
  },
  {
    "id": "ro.constitutia.titlu_ii.capitol_i.art_16",
    "type": "articol",
    "raw_text": "Art. 16",
    "hierarchy_path": [
      "II",
